function setMode(admin) {
  isAdmin = admin;
  const banner = document.getElementById('mode-banner');
  const label = document.getElementById('mode-label');
  const btn = document.getElementById('btn-toggle-mode');
  if (admin) {
    banner.classList.add('admin');
    label.textContent = 'מצב ניהול - אחראית הספרייה';
    btn.textContent = 'יציאה ממצב ניהול';
  } else {
    banner.classList.remove('admin');
    label.textContent = 'תצוגה ציבורית - קריאה בלבד';
    btn.textContent = 'כניסת אחראית';
  }
  renderAll();
}

