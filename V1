const DEFAULT_PASSWORD = 'canta';

let books = [];
let history = [];
let isAdmin = false;
let editingId = null;

/* ============ STORAGE ============ */
function load() {
  const stored = localStorage.getItem(STORAGE_KEY);
  if (stored) {
    try { books = JSON.parse(stored); }
    catch(e) { books = [...INITIAL_BOOKS]; }
  } else {
    books = JSON.parse(JSON.stringify(INITIAL_BOOKS));
    save();
  }
  const h = localStorage.getItem(HISTORY_KEY);
  history = h ? JSON.parse(h) : [];
}
function save() {
  localStorage.setItem(STORAGE_KEY, JSON.stringify(books));
}
function saveHistory() {
  localStorage.setItem(HISTORY_KEY, JSON.stringify(history));
}
function getPassword() {
  return localStorage.getItem(PASSWORD_KEY) || DEFAULT_PASSWORD;
}

/* ============ HELPERS ============ */
function todayISO() {
  return new Date().toISOString().slice(0,10);
}
function formatDate(d) {
  if (!d) return '';
  // Try to handle multiple formats
  if (/^\d{4}-\d{2}-\d{2}/.test(d)) {
    const dt = new Date(d);
    return `${dt.getDate()}.${dt.getMonth()+1}.${dt.getFullYear()%100}`;
  }
  return d;
}
function isOverdue(book) {
  if (book.status !== 'borrowed') return false;
  if (!book.expectedReturn) {
    if (book.borrowDate) {
      // Default 21 days if no expected return set
      const d = parseLooseDate(book.borrowDate);
      if (d) {
        const limit = new Date(d.getTime() + 21*24*60*60*1000);
        return new Date() > limit;
      }
    }
    return false;
  }
  const exp = parseLooseDate(book.expectedReturn);
  return exp && new Date() > exp;
}
function parseLooseDate(s) {
  if (!s) return null;
  if (/^\d{4}-\d{2}-\d{2}/.test(s)) return new Date(s);
  // Try formats like 11.1.26 or 5.4.26
  const m = s.match(/^(\d{1,2})\.(\d{1,2})\.(\d{2,4})$/);
  if (m) {
    let [_,d,mo,y] = m;
    y = parseInt(y); if (y < 100) y += 2000;
    return new Date(parseInt(y), parseInt(mo)-1, parseInt(d));
  }
  const d = new Date(s);
  return isNaN(d) ? null : d;
}
function statusLabel(s) {
  return {available: 'פנוי', borrowed: 'מושאל', not_for_borrowing: 'לא להשאלה'}[s] || s;
}
function categoryLabel(c) {
  return {
    'adults': 'מבוגרים', 'kids & teens': 'ילדים ונוער',
    'healing': 'ריפוי', 'educational': 'חינוכי',
    'music': 'מוזיקה', 'game': 'משחק'
  }[c] || c;
}
function languageLabel(l) {
  return {'Hebrew':'עברית','English':'אנגלית','Spanish':'ספרדית','Portuguese':'פורטוגזית','International':'בינלאומי'}[l] || l;
}
function logHistory(action, book, extra) {
  history.unshift({
    ts: new Date().toISOString(),
    action: action,
    bookId: book.id,
    bookTitle: book.title,
    borrower: extra?.borrower || book.borrower || '',
    notes: extra?.notes || ''
  });
  if (history.length > 500) history = history.slice(0,500);
  saveHistory();
}
function toast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2400);
}
function nextId() {
  return books.reduce((m,b) => Math.max(m, b.id||0), 0) + 1;
}

/* ============ RENDER ============ */
function populateFilters() {
  const langs = [...new Set(books.map(b => b.language).filter(Boolean))].sort();
  const cats = [...new Set(books.map(b => b.category).filter(Boolean))].sort();
  const langSel = document.getElementById('filter-language');
  const catSel = document.getElementById('filter-category');
  langSel.innerHTML = '<option value="">כל השפות</option>' +
    langs.map(l => `<option value="${l}">${languageLabel(l)}</option>`).join('');
  catSel.innerHTML = '<option value="">כל הקטגוריות</option>' +
    cats.map(c => `<option value="${c}">${categoryLabel(c)}</option>`).join('');
}

function renderStats() {
  document.getElementById('stat-total').textContent = books.length;
  document.getElementById('stat-available').textContent =
    books.filter(b => b.status === 'available').length;
  document.getElementById('stat-borrowed').textContent =
    books.filter(b => b.status === 'borrowed').length;
  const overdue = books.filter(b => isOverdue(b)).length;
  const notLending = books.filter(b => b.status === 'not_for_borrowing').length;
  document.getElementById('stat-overdue').textContent = overdue + ' / ' + notLending;
}

function getFiltered() {
  const q = document.getElementById('search').value.trim().toLowerCase();
  const fs = document.getElementById('filter-status').value;
  const fl = document.getElementById('filter-language').value;
  const fc = document.getElementById('filter-category').value;
  return books.filter(b => {
    if (q) {
      const hay = `${b.title} ${b.author} ${b.borrower}`.toLowerCase();
      if (!hay.includes(q)) return false;
    }
    if (fs === 'overdue') { if (!isOverdue(b)) return false; }
    else if (fs && b.status !== fs) return false;
    if (fl && b.language !== fl) return false;
    if (fc && b.category !== fc) return false;
    return true;
  });
}

function renderBooks() {
  const tbody = document.getElementById('books-tbody');
  const list = getFiltered();
  // Sort: overdue first, then borrowed, then available, then not_for_borrowing
  list.sort((a,b) => {
    const order = (x) => isOverdue(x) ? 0 : (x.status==='borrowed'?1 : (x.status==='available'?2 : 3));
    const oa = order(a), ob = order(b);
    if (oa !== ob) return oa - ob;
    return (a.title||'').localeCompare(b.title||'', 'he');
  });
  tbody.innerHTML = list.map(b => {
    const overdue = isOverdue(b);
    const rowClass = overdue ? 'overdue' : b.status;
    const badgeClass = overdue ? 'overdue' : b.status;
    const badgeText = overdue ? 'באיחור' : statusLabel(b.status);
    let borrowerHTML = '';
    if (b.status === 'borrowed' && b.borrower) {
      borrowerHTML = `
        <div class="borrower-info">
          <span class="name">${esc(b.borrower)}</span>
          ${b.phone ? `<div class="meta">📞 ${esc(b.phone)}</div>` : ''}
          ${b.email ? `<div class="meta">✉ ${esc(b.email)}</div>` : ''}
          ${b.borrowDate ? `<div class="meta">הושאל: ${esc(formatDate(b.borrowDate))}</div>` : ''}
          ${b.expectedReturn ? `<div class="meta">צפי: ${esc(formatDate(b.expectedReturn))}</div>` : ''}
        </div>`;
    }
    let actionsHTML = '';
    if (isAdmin) {
      if (b.status === 'available') {
        actionsHTML += `<button class="btn-gold" data-act="borrow" data-id="${b.id}">השאלה</button>`;
      } else if (b.status === 'borrowed') {
        actionsHTML += `<button class="btn-gold" data-act="return" data-id="${b.id}">החזרה</button>`;
      }
      actionsHTML += `<button class="btn-ghost" data-act="edit" data-id="${b.id}">עריכה</button>`;
      actionsHTML += `<button class="btn-danger" data-act="delete" data-id="${b.id}">מחיקה</button>`;
    }
    return `
      <tr class="${rowClass}" data-id="${b.id}">
        <td>
          <div class="book-title">${esc(b.title)}</div>
          ${b.author ? `<div class="book-author">${esc(b.author)}</div>` : ''}
        </td>
        <td>${esc(languageLabel(b.language))}</td>
        <td>${esc(categoryLabel(b.category))}</td>
        <td><span class="badge ${badgeClass}">${badgeText}</span></td>
        <td>${borrowerHTML || '<span style="opacity:0.5">—</span>'}</td>
        <td>${esc(b.owner || '')}</td>
        ${isAdmin ? `<td><div class="row-actions">${actionsHTML}</div></td>` : ''}
      </tr>
    `;
  }).join('');
  document.getElementById('empty-msg').style.display = list.length ? 'none' : 'block';
}

function esc(s) {
  if (s === null || s === undefined) return '';
  return String(s).replace(/[&<>"']/g, m => ({
    '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'
  }[m]));
}

function renderAll() {
  populateFilters();
  renderStats();
  renderBooks();
  // toggle admin columns
  document.querySelectorAll('.admin-only').forEach(el => {
    el.style.display = isAdmin ? '' : 'none';
  });
}

