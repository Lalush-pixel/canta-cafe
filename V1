<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ספריית קנטה - Library at the Canta</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Frank+Ruhl+Libre:wght@400;500;700;900&family=Cinzel:wght@400;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --burgundy: #6B1F1F;
    --burgundy-dark: #4A1414;
    --burgundy-light: #8B3030;
    --cream: #F4E4BC;
    --cream-light: #FBF1D9;
    --cream-dark: #E5CFA0;
    --gold: #D4A84B;
    --gold-dark: #A8842F;
    --green: #4A5D3A;
    --green-dark: #2F3E25;
    --ink: #3A1F0F;
    --paper: #F8EAC8;
    --shadow: rgba(74, 20, 20, 0.15);
  }
  * { box-sizing: border-box; }
  html, body {
    margin: 0;
    padding: 0;
    font-family: 'Frank Ruhl Libre', 'Times New Roman', serif;
    background: var(--cream);
    color: var(--ink);
    min-height: 100vh;
  }
  body {
    background:
      radial-gradient(ellipse at top, var(--cream-light) 0%, var(--cream) 60%, var(--cream-dark) 100%);
    background-attachment: fixed;
  }
  /* Decorative tribal border pattern */
  .ornamental-border {
    height: 28px;
    background-image:
      repeating-linear-gradient(90deg,
        var(--burgundy) 0, var(--burgundy) 8px,
        transparent 8px, transparent 16px,
        var(--burgundy) 16px, var(--burgundy) 18px,
        transparent 18px, transparent 28px);
    background-size: 28px 100%;
    position: relative;
    overflow: hidden;
  }
  .ornamental-border::before {
    content: '◆ ❖ ◆ ❖ ◆ ❖ ◆ ❖ ◆ ❖ ◆ ❖ ◆ ❖ ◆ ❖ ◆ ❖ ◆ ❖ ◆ ❖ ◆ ❖ ◆ ❖ ◆ ❖ ◆ ❖ ◆ ❖ ◆ ❖ ◆ ❖ ◆ ❖ ◆ ❖ ◆ ❖';
    position: absolute;
    inset: 0;
    color: var(--gold);
    font-size: 16px;
    letter-spacing: 4px;
    text-align: center;
    line-height: 28px;
    background: var(--burgundy-dark);
    opacity: 1;
    white-space: nowrap;
    overflow: hidden;
  }
  header {
    background: var(--cream-light);
    padding: 0;
    position: relative;
    border-bottom: 1px solid var(--burgundy);
  }
  .header-inner {
    text-align: center;
    padding: 32px 20px 28px;
    background:
      radial-gradient(ellipse at center, var(--cream-light) 0%, var(--cream) 100%);
  }
  .logo {
    width: 180px;
    height: 110px;
    margin: 0 auto 12px;
    display: block;
  }
  .site-title {
    font-family: 'Cinzel', 'Frank Ruhl Libre', serif;
    font-size: 38px;
    font-weight: 700;
    color: var(--burgundy);
    margin: 8px 0 4px;
    letter-spacing: 1px;
  }
  .site-subtitle {
    font-family: 'Cinzel', serif;
    font-size: 16px;
    color: var(--burgundy-light);
    letter-spacing: 6px;
    text-transform: uppercase;
    margin: 0;
  }
  .header-divider {
    margin: 14px auto 0;
    width: 280px;
    height: 18px;
    color: var(--gold-dark);
    text-align: center;
    font-size: 14px;
    letter-spacing: 6px;
  }
  /* Main container - parchment style */
  .container {
    max-width: 1200px;
    margin: 28px auto;
    padding: 0 16px;
  }
  .panel {
    background: var(--paper);
    border: 2px solid var(--burgundy);
    border-radius: 4px;
    padding: 28px;
    box-shadow: 0 4px 20px var(--shadow);
    position: relative;
  }
  .panel::before, .panel::after {
    content: '';
    position: absolute;
    width: 22px; height: 22px;
    border: 2px solid var(--gold-dark);
  }
  .panel::before { top: 8px; right: 8px; border-left: none; border-bottom: none; }
  .panel::after { bottom: 8px; left: 8px; border-right: none; border-top: none; }

  /* Stats bar */
  .stats {
    display: flex;
    gap: 16px;
    margin-bottom: 22px;
    flex-wrap: wrap;
  }
  .stat-card {
    flex: 1;
    min-width: 140px;
    background: var(--cream-light);
    border: 1.5px solid var(--burgundy);
    padding: 14px 16px;
    text-align: center;
    border-radius: 3px;
  }
  .stat-card .num {
    font-family: 'Cinzel', serif;
    font-size: 30px;
    font-weight: 700;
    color: var(--burgundy);
    display: block;
    line-height: 1;
  }
  .stat-card .label {
    font-size: 13px;
    color: var(--green-dark);
    margin-top: 6px;
    display: block;
    letter-spacing: 1px;
  }
  .stat-card.borrowed .num { color: var(--gold-dark); }
  .stat-card.notavail .num { color: var(--green-dark); }

  /* Toolbar */
  .toolbar {
    display: flex;
    gap: 12px;
    margin-bottom: 18px;
    flex-wrap: wrap;
    align-items: center;
  }
  .search-box {
    flex: 2;
    min-width: 220px;
    position: relative;
  }
  .search-box input {
    width: 100%;
    padding: 11px 38px 11px 14px;
    border: 1.5px solid var(--burgundy);
    background: var(--cream-light);
    color: var(--ink);
    font-family: inherit;
    font-size: 16px;
    border-radius: 3px;
    direction: rtl;
  }
  .search-box::after {
    content: '⌕';
    position: absolute;
    right: 12px; top: 50%;
    transform: translateY(-50%);
    color: var(--burgundy);
    font-size: 18px;
    pointer-events: none;
  }
  select, button, input[type="text"], input[type="email"], input[type="tel"], input[type="date"], input[type="password"], textarea {
    font-family: inherit;
    font-size: 15px;
  }
  .filter-select {
    padding: 11px 14px;
    border: 1.5px solid var(--burgundy);
    background: var(--cream-light);
    color: var(--ink);
    border-radius: 3px;
    cursor: pointer;
    min-width: 130px;
  }
  button {
    cursor: pointer;
    border: none;
    border-radius: 3px;
    transition: all 0.15s;
    font-weight: 500;
  }
  .btn-primary {
    padding: 11px 22px;
    background: var(--burgundy);
    color: var(--cream-light);
    border: 1.5px solid var(--burgundy-dark);
    letter-spacing: 0.5px;
  }
  .btn-primary:hover { background: var(--burgundy-dark); }
  .btn-secondary {
    padding: 11px 18px;
    background: var(--cream-light);
    color: var(--burgundy);
    border: 1.5px solid var(--burgundy);
  }
  .btn-secondary:hover { background: var(--cream-dark); }
  .btn-ghost {
    padding: 9px 16px;
    background: transparent;
    color: var(--burgundy);
    border: 1px solid var(--burgundy-light);
  }
  .btn-ghost:hover { background: var(--cream-light); }
  .btn-danger {
    padding: 9px 14px;
    background: transparent;
    color: var(--burgundy-dark);
    border: 1px solid var(--burgundy);
  }
  .btn-danger:hover { background: var(--burgundy); color: var(--cream-light); }
  .btn-gold {
    padding: 11px 22px;
    background: var(--gold);
    color: var(--burgundy-dark);
    border: 1.5px solid var(--gold-dark);
    font-weight: 700;
  }
  .btn-gold:hover { background: var(--gold-dark); color: var(--cream-light); }

  /* Mode banner */
  .mode-banner {
    margin-bottom: 18px;
    padding: 12px 18px;
    background: var(--cream-light);
    border: 1.5px solid var(--gold-dark);
    border-radius: 3px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .mode-banner.admin { border-color: var(--burgundy); background: linear-gradient(90deg, var(--paper), var(--cream-light)); }
  .mode-banner .label {
    font-family: 'Cinzel', serif;
    color: var(--burgundy);
    letter-spacing: 1px;
    font-size: 14px;
  }
  .mode-banner.admin .label::before { content: '🔓 '; }
  .mode-banner:not(.admin) .label::before { content: '👁 '; }

  /* Table */
  .books-wrapper {
    overflow-x: auto;
    border: 1.5px solid var(--burgundy);
    border-radius: 3px;
    background: var(--cream-light);
  }
  table {
    width: 100%;
    border-collapse: collapse;
    min-width: 700px;
  }
  thead th {
    background: var(--burgundy);
    color: var(--cream-light);
    padding: 12px 10px;
    text-align: right;
    font-family: 'Cinzel', serif;
    font-size: 13px;
    letter-spacing: 1px;
    font-weight: 600;
    border-bottom: 2px solid var(--gold-dark);
  }
  tbody td {
    padding: 11px 10px;
    border-bottom: 1px solid var(--cream-dark);
    vertical-align: middle;
    font-size: 14px;
  }
  tbody tr:hover { background: var(--cream); }
  tbody tr.borrowed { background: rgba(212, 168, 75, 0.08); }
  tbody tr.borrowed:hover { background: rgba(212, 168, 75, 0.18); }
  tbody tr.not_for_borrowing { background: rgba(74, 93, 58, 0.06); }
  tbody tr.overdue { background: rgba(139, 48, 48, 0.12); }
  tbody tr.overdue:hover { background: rgba(139, 48, 48, 0.2); }

  .badge {
    display: inline-block;
    padding: 4px 10px;
    border-radius: 12px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.5px;
    white-space: nowrap;
  }
  .badge.available { background: #C8D6B0; color: var(--green-dark); border: 1px solid var(--green); }
  .badge.borrowed { background: #F0D9A0; color: var(--gold-dark); border: 1px solid var(--gold-dark); }
  .badge.not_for_borrowing { background: var(--cream-dark); color: var(--ink); border: 1px solid var(--burgundy-light); }
  .badge.overdue { background: #E8B0B0; color: var(--burgundy-dark); border: 1px solid var(--burgundy); }

  .book-title {
    font-weight: 700;
    color: var(--burgundy-dark);
    font-size: 15px;
  }
  .book-author {
    font-size: 13px;
    color: var(--ink);
    opacity: 0.75;
  }
  .borrower-info {
    font-size: 13px;
    color: var(--ink);
  }
  .borrower-info .name { font-weight: 600; }
  .borrower-info .meta { opacity: 0.7; font-size: 12px; }
  .row-actions {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    justify-content: flex-start;
  }
  .row-actions button {
    padding: 5px 10px;
    font-size: 12px;
  }

  /* Modal */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(58, 31, 15, 0.6);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 100;
    padding: 20px;
  }
  .modal-overlay.show { display: flex; }
  .modal {
    background: var(--paper);
    border: 2px solid var(--burgundy);
    border-radius: 4px;
    max-width: 580px;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
    padding: 28px;
    position: relative;
    box-shadow: 0 10px 40px rgba(0,0,0,0.3);
  }
  .modal::before, .modal::after {
    content: '';
    position: absolute;
    width: 22px; height: 22px;
    border: 2px solid var(--gold-dark);
  }
  .modal::before { top: 8px; right: 8px; border-left: none; border-bottom: none; }
  .modal::after { bottom: 8px; left: 8px; border-right: none; border-top: none; }
  .modal h2 {
    font-family: 'Cinzel', serif;
    color: var(--burgundy);
    margin: 0 0 18px;
    font-size: 24px;
    text-align: center;
    border-bottom: 1px solid var(--gold-dark);
    padding-bottom: 12px;
  }
  .modal-close {
    position: absolute;
    top: 12px; left: 12px;
    background: transparent;
    border: none;
    font-size: 24px;
    color: var(--burgundy);
    cursor: pointer;
    line-height: 1;
    padding: 4px 8px;
  }
  .field {
    margin-bottom: 14px;
  }
  .field label {
    display: block;
    margin-bottom: 5px;
    font-size: 13px;
    color: var(--burgundy);
    font-weight: 600;
    letter-spacing: 0.5px;
  }
  .field input, .field select, .field textarea {
    width: 100%;
    padding: 9px 12px;
    border: 1.5px solid var(--burgundy-light);
    background: var(--cream-light);
    color: var(--ink);
    border-radius: 3px;
    font-family: inherit;
    font-size: 15px;
    direction: rtl;
  }
  .field textarea { min-height: 70px; resize: vertical; }
  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .modal-actions {
    display: flex;
    gap: 10px;
    justify-content: center;
    margin-top: 20px;
    flex-wrap: wrap;
  }
  .empty {
    text-align: center;
    padding: 40px 20px;
    color: var(--ink);
    opacity: 0.65;
    font-style: italic;
  }
  .login-form {
    text-align: center;
  }
  .login-form input {
    text-align: center;
    letter-spacing: 4px;
    font-size: 18px;
  }
  .hint {
    font-size: 12px;
    color: var(--ink);
    opacity: 0.65;
    margin-top: 8px;
    text-align: center;
  }
  footer {
    text-align: center;
    padding: 30px 20px;
    color: var(--burgundy);
    font-family: 'Cinzel', serif;
    letter-spacing: 3px;
    font-size: 12px;
  }
  /* Toast */
  .toast {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%) translateY(120%);
    background: var(--burgundy);
    color: var(--cream-light);
    padding: 12px 22px;
    border-radius: 3px;
    border: 1.5px solid var(--gold);
    z-index: 200;
    transition: transform 0.3s;
    font-size: 14px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.3);
  }
  .toast.show { transform: translateX(-50%) translateY(0); }

  @media (max-width: 700px) {
    .site-title { font-size: 28px; }
    .panel { padding: 18px; }
    .field-row { grid-template-columns: 1fr; }
    .stat-card { min-width: 100px; }
    .stat-card .num { font-size: 22px; }
    thead th, tbody td { padding: 8px 6px; font-size: 12.5px; }
  }
</style>
</head>
<body>
  <div class="ornamental-border"></div>
  <header>
    <div class="header-inner">
      <svg class="logo" viewBox="0 0 360 220" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="dots" patternUnits="userSpaceOnUse" width="14" height="14">
            <circle cx="7" cy="7" r="1.4" fill="#6B1F1F"/>
          </pattern>
        </defs>
        <!-- Outer diamond -->
        <polygon points="180,18 348,110 180,202 12,110" fill="none" stroke="#6B1F1F" stroke-width="6"/>
        <!-- Inner diamond -->
        <polygon points="180,38 322,110 180,182 38,110" fill="none" stroke="#6B1F1F" stroke-width="2"/>
        <!-- Decorative dots between -->
        <g fill="#6B1F1F">
          <circle cx="180" cy="28" r="3"/>
          <circle cx="335" cy="110" r="3"/>
          <circle cx="180" cy="192" r="3"/>
          <circle cx="25" cy="110" r="3"/>
        </g>
        <!-- Top ornament -->
        <path d="M 150,68 Q 180,52 210,68" fill="none" stroke="#6B1F1F" stroke-width="2"/>
        <path d="M 156,72 Q 180,60 204,72" fill="none" stroke="#6B1F1F" stroke-width="1.5"/>
        <!-- Bottom ornament -->
        <path d="M 150,156 Q 180,170 210,156" fill="none" stroke="#6B1F1F" stroke-width="2"/>
        <path d="M 156,150 Q 180,162 204,150" fill="none" stroke="#6B1F1F" stroke-width="1.5"/>
        <!-- Side ornaments -->
        <text x="60" y="115" font-family="serif" font-size="18" fill="#6B1F1F" text-anchor="middle">❖</text>
        <text x="300" y="115" font-family="serif" font-size="18" fill="#6B1F1F" text-anchor="middle">❖</text>
        <!-- Title -->
        <text x="180" y="118" font-family="Cinzel, serif" font-size="38" font-weight="700" fill="#6B1F1F" text-anchor="middle" letter-spacing="3">CANTA</text>
        <line x1="100" y1="128" x2="260" y2="128" stroke="#6B1F1F" stroke-width="1"/>
        <text x="180" y="148" font-family="Cinzel, serif" font-size="14" font-style="italic" fill="#6B1F1F" text-anchor="middle">- Art Café -</text>
      </svg>
      <h1 class="site-title">ספרייה קהילתית</h1>
      <p class="site-subtitle">Library at the Canta</p>
      <div class="header-divider">❖ ◆ ❖ ◆ ❖ ◆ ❖</div>
    </div>
  </header>
  <div class="ornamental-border"></div>

  <div class="container">
    <div class="panel">
      <!-- Mode Banner -->
      <div id="mode-banner" class="mode-banner">
        <span class="label" id="mode-label">תצוגה ציבורית - קריאה בלבד</span>
        <div>
          <button class="btn-secondary" id="btn-toggle-mode">כניסת אחראית</button>
        </div>
      </div>

      <!-- Stats -->
      <div class="stats">
        <div class="stat-card">
          <span class="num" id="stat-total">0</span>
          <span class="label">סה״כ ספרים</span>
        </div>
        <div class="stat-card">
          <span class="num" id="stat-available">0</span>
          <span class="label">פנויים להשאלה</span>
        </div>
        <div class="stat-card borrowed">
          <span class="num" id="stat-borrowed">0</span>
          <span class="label">מושאלים כרגע</span>
        </div>
        <div class="stat-card notavail">
          <span class="num" id="stat-overdue">0</span>
          <span class="label">באיחור / לא להשאלה</span>
        </div>
      </div>

      <!-- Toolbar -->
      <div class="toolbar">
        <div class="search-box">
          <input type="text" id="search" placeholder="חיפוש לפי שם הספר, מחבר או משאיל...">
        </div>
        <select id="filter-status" class="filter-select">
          <option value="">כל הסטטוסים</option>
          <option value="available">פנוי</option>
          <option value="borrowed">מושאל</option>
          <option value="not_for_borrowing">לא להשאלה</option>
          <option value="overdue">באיחור</option>
        </select>
        <select id="filter-language" class="filter-select">
          <option value="">כל השפות</option>
        </select>
        <select id="filter-category" class="filter-select">
          <option value="">כל הקטגוריות</option>
        </select>
        <button class="btn-ghost" id="btn-clear-filters">נקה סינון</button>
      </div>

      <!-- Admin actions -->
      <div class="toolbar admin-only" style="display:none">
        <button class="btn-primary" id="btn-add-book">+ הוספת ספר חדש</button>
        <button class="btn-secondary" id="btn-export-json">ייצוא JSON</button>
        <button class="btn-secondary" id="btn-export-csv">ייצוא Excel/CSV</button>
        <button class="btn-secondary" id="btn-import">ייבוא נתונים</button>
        <input type="file" id="file-import" accept=".json,.csv" style="display:none">
        <button class="btn-ghost" id="btn-history">היסטוריית השאלות</button>
      </div>

      <!-- Books table -->
      <div class="books-wrapper">
        <table id="books-table">
          <thead>
            <tr>
              <th>הספר</th>
              <th>שפה</th>
              <th>קטגוריה</th>
              <th>סטטוס</th>
              <th>פרטי השאלה</th>
              <th>בעלים</th>
              <th class="admin-only" style="display:none">פעולות</th>
            </tr>
          </thead>
          <tbody id="books-tbody"></tbody>
        </table>
        <div id="empty-msg" class="empty" style="display:none">לא נמצאו ספרים התואמים לחיפוש</div>
      </div>
    </div>
  </div>

  <!-- Modal: Login -->
  <div class="modal-overlay" id="modal-login">
    <div class="modal" style="max-width:420px">
      <button class="modal-close" data-close>×</button>
      <h2>כניסת אחראית</h2>
      <form id="login-form" class="login-form">
        <div class="field">
          <label>סיסמה</label>
          <input type="password" id="login-password" required autocomplete="current-password">
        </div>
        <div class="modal-actions">
          <button type="submit" class="btn-primary">כניסה</button>
        </div>
        <div class="hint">סיסמה ראשונית: <strong>canta</strong> (ניתן לשנות בהגדרות)</div>
      </form>
    </div>
  </div>

  <!-- Modal: Add/Edit Book -->
  <div class="modal-overlay" id="modal-book">
    <div class="modal">
      <button class="modal-close" data-close>×</button>
      <h2 id="book-modal-title">הוספת ספר חדש</h2>
      <form id="book-form">
        <input type="hidden" id="book-id">
        <div class="field-row">
          <div class="field">
            <label>שם הספר</label>
            <input type="text" id="book-title" required>
          </div>
          <div class="field">
            <label>מחבר</label>
            <input type="text" id="book-author">
          </div>
        </div>
        <div class="field-row">
          <div class="field">
            <label>שפה</label>
            <select id="book-language">
              <option value="Hebrew">עברית</option>
              <option value="English">אנגלית</option>
              <option value="Spanish">ספרדית</option>
