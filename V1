    alert('סיסמה שגויה');
  }
});
document.getElementById('search').addEventListener('input', renderBooks);
document.getElementById('filter-status').addEventListener('change', renderBooks);
document.getElementById('filter-language').addEventListener('change', renderBooks);
document.getElementById('filter-category').addEventListener('change', renderBooks);
