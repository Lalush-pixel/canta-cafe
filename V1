}
document.querySelectorAll('[data-close]').forEach(b => {
  b.addEventListener('click', e => {
    e.target.closest('.modal-overlay').classList.remove('show');
  });
});
document.querySelectorAll('.modal-overlay').forEach(o => {
  o.addEventListener('click', e => {
    if (e.target === o) o.classList.remove('show');
  });
});

/* ============ BOOK FORM ============ */
function openAddBook() {
  editingId = null;
  document.getElementById('book-modal-title').textContent = 'הוספת ספר חדש';
  document.getElementById('book-form').reset();
  document.getElementById('book-id').value = '';
  openModal('modal-book');
}
function openEditBook(id) {
  const b = books.find(x => x.id === id);
  if (!b) return;
  editingId = id;
  document.getElementById('book-modal-title').textContent = 'עריכת ספר';
  document.getElementById('book-id').value = id;
  document.getElementById('book-title').value = b.title || '';
  document.getElementById('book-author').value = b.author || '';
  document.getElementById('book-language').value = b.language || 'Hebrew';
  document.getElementById('book-category').value = b.category || 'adults';
  document.getElementById('book-owner').value = b.owner || 'RT';
  document.getElementById('book-status').value = b.status || 'available';
  openModal('modal-book');
}
document.getElementById('book-form').addEventListener('submit', e => {
  e.preventDefault();
  const data = {
    title: document.getElementById('book-title').value.trim(),
    author: document.getElementById('book-author').value.trim(),
    language: document.getElementById('book-language').value,
    category: document.getElementById('book-category').value,
    owner: document.getElementById('book-owner').value,
    status: document.getElementById('book-status').value
  };
  if (editingId) {
    const b = books.find(x => x.id === editingId);
    Object.assign(b, data);
    logHistory('עריכת ספר', b);
    toast('הספר עודכן בהצלחה');
  } else {
    const newBook = {
      id: nextId(), ...data,
      borrowDate: '', borrower: '', email: '', phone: '',
      expectedReturn: '', notes: ''
    };
    books.push(newBook);
    logHistory('הוספת ספר', newBook);
    toast('הספר נוסף בהצלחה');
  }
  save();
  renderAll();
  closeModal('modal-book');
});

/* ============ BORROW ============ */
function openBorrow(id) {
  const b = books.find(x => x.id === id);
  if (!b) return;
  document.getElementById('borrow-form').reset();
  document.getElementById('borrow-book-id').value = id;
  document.getElementById('borrow-book-title').value = b.title;
  document.getElementById('borrow-date').value = todayISO();
  // default expected return: 21 days
  const exp = new Date(Date.now() + 21*24*60*60*1000);
  document.getElementById('borrow-expected').value = exp.toISOString().slice(0,10);
  openModal('modal-borrow');
}
document.getElementById('borrow-form').addEventListener('submit', e => {
  e.preventDefault();
  const id = parseInt(document.getElementById('borrow-book-id').value);
  const b = books.find(x => x.id === id);
  if (!b) return;
  b.status = 'borrowed';
  b.borrower = document.getElementById('borrow-name').value.trim();
  b.phone = document.getElementById('borrow-phone').value.trim();
  b.email = document.getElementById('borrow-email').value.trim();
  b.borrowDate = document.getElementById('borrow-date').value;
  b.expectedReturn = document.getElementById('borrow-expected').value;
  b.notes = document.getElementById('borrow-notes').value.trim();
  logHistory('השאלה', b, {borrower: b.borrower, notes: b.notes});
  save();
  renderAll();
  closeModal('modal-borrow');
  toast(`הספר "${b.title}" הושאל ל${b.borrower}`);
});

/* ============ RETURN ============ */
function openReturn(id) {
  const b = books.find(x => x.id === id);
  if (!b) return;
  document.getElementById('return-form').reset();
  document.getElementById('return-book-id').value = id;
  document.getElementById('return-summary').innerHTML = `
    <div><strong>הספר:</strong> ${esc(b.title)}</div>
    <div><strong>הושאל ל:</strong> ${esc(b.borrower)}</div>
    ${b.phone ? `<div><strong>טלפון:</strong> ${esc(b.phone)}</div>` : ''}
    ${b.borrowDate ? `<div><strong>תאריך השאלה:</strong> ${esc(formatDate(b.borrowDate))}</div>` : ''}
    ${b.expectedReturn ? `<div><strong>צפי החזרה:</strong> ${esc(formatDate(b.expectedReturn))}</div>` : ''}
    ${b.notes ? `<div><strong>הערות:</strong> ${esc(b.notes)}</div>` : ''}
  `;
  openModal('modal-return');
}
document.getElementById('return-form').addEventListener('submit', e => {
  e.preventDefault();
  const id = parseInt(document.getElementById('return-book-id').value);
  const b = books.find(x => x.id === id);
  if (!b) return;
  const returnNotes = document.getElementById('return-notes').value.trim();
  logHistory('החזרה', b, {borrower: b.borrower, notes: returnNotes});
  b.status = 'available';
  b.borrower = '';
  b.phone = '';
  b.email = '';
  b.borrowDate = '';
  b.expectedReturn = '';
  b.notes = '';
  save();
  renderAll();
  closeModal('modal-return');
  toast('הספר הוחזר בהצלחה');
});

/* ============ DELETE ============ */
function deleteBook(id) {
  const b = books.find(x => x.id === id);
  if (!b) return;
  if (!confirm(`האם למחוק את הספר "${b.title}"?\nפעולה זו אינה ניתנת לביטול.`)) return;
  logHistory('מחיקת ספר', b);
  books = books.filter(x => x.id !== id);
  save();
  renderAll();
  toast('הספר נמחק');
}

/* ============ HISTORY ============ */
function renderHistory() {
  const q = document.getElementById('history-search').value.trim().toLowerCase();
  const list = q ? history.filter(h =>
    (h.bookTitle + ' ' + h.borrower + ' ' + h.action + ' ' + h.notes).toLowerCase().includes(q)
  ) : history;
  document.getElementById('history-tbody').innerHTML = list.map(h => {
    const dt = new Date(h.ts);
    const dtStr = `${dt.getDate()}.${dt.getMonth()+1}.${dt.getFullYear()%100} ${String(dt.getHours()).padStart(2,'0')}:${String(dt.getMinutes()).padStart(2,'0')}`;
    return `<tr>
      <td>${dtStr}</td>
      <td>${esc(h.action)}</td>
      <td>${esc(h.bookTitle)}</td>
      <td>${esc(h.borrower || '')}</td>
      <td>${esc(h.notes || '')}</td>
    </tr>`;
  }).join('');
  document.getElementById('history-empty').style.display = list.length ? 'none' : 'block';
}
document.getElementById('history-search').addEventListener('input', renderHistory);
document.getElementById('btn-clear-history').addEventListener('click', () => {
  if (!confirm('למחוק את כל היסטוריית ההשאלות?')) return;
  history = [];
  saveHistory();
  renderHistory();
  toast('ההיסטוריה נוקתה');
});

/* ============ EXPORT/IMPORT ============ */
function exportJSON() {
  const data = JSON.stringify({books, history, exportedAt: new Date().toISOString()}, null, 2);
  const blob = new Blob([data], {type: 'application/json'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `canta-library-${todayISO()}.json`;
  a.click();
  URL.revokeObjectURL(url);
  toast('הקובץ ירד בהצלחה');
}
function exportCSV() {
  const headers = ['Title','Author','Language','Category','Status','BorrowDate','Borrower','Email','Phone','Owner','ExpectedReturn','Notes'];
  const escCSV = (v) => {
    if (v === null || v === undefined) return '';
    const s = String(v);
    return /[",\n]/.test(s) ? '"' + s.replace(/"/g,'""') + '"' : s;
  };
  const rows = [headers.join(',')].concat(books.map(b => [
    b.title,b.author,b.language,b.category,b.status,b.borrowDate,
    b.borrower,b.email,b.phone,b.owner,b.expectedReturn,b.notes
  ].map(escCSV).join(',')));
  const bom = '\ufeff'; // utf-8 BOM for Excel
  const blob = new Blob([bom + rows.join('\n')], {type: 'text/csv;charset=utf-8'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `canta-library-${todayISO()}.csv`;
  a.click();
  URL.revokeObjectURL(url);
  toast('הקובץ ירד בהצלחה');
}
function importFile(file) {
  const reader = new FileReader();
  reader.onload = e => {
    try {
      let data;
      if (file.name.endsWith('.json')) {
        const parsed = JSON.parse(e.target.result);
        data = Array.isArray(parsed) ? parsed : parsed.books;
        if (parsed.history) {
          if (confirm('האם לייבא גם את ההיסטוריה?')) history = parsed.history;
        }
      } else {
        // CSV
        const lines = e.target.result.replace(/^\ufeff/,'').split(/\r?\n/).filter(Boolean);
        const headers = parseCSVLine(lines[0]);
        data = lines.slice(1).map((line, i) => {
          const vals = parseCSVLine(line);
          const obj = {id: i+1};
          headers.forEach((h,j) => {
            const key = h.charAt(0).toLowerCase() + h.slice(1);
            obj[key] = vals[j] || '';
          });
          // Ensure required fields
          obj.borrowDate = obj.borrowDate || '';
          obj.expectedReturn = obj.expectedReturn || '';
          obj.notes = obj.notes || '';
          return obj;
        });
      }
      if (!Array.isArray(data) || !data.length) throw new Error('No data');
      if (!confirm(`לייבא ${data.length} ספרים? פעולה זו תחליף את הנתונים הקיימים.`)) return;
      // Re-id to avoid conflicts
      data.forEach((b,i) => { b.id = i+1; });
      books = data;
      save();
      renderAll();
      toast(`יובאו ${data.length} ספרים בהצלחה`);
    } catch(err) {
      alert('שגיאה בייבוא: ' + err.message);
    }
  };
  reader.readAsText(file, 'utf-8');
}
function parseCSVLine(line) {
  const result = [];
  let cur = '', inQ = false;
  for (let i=0; i<line.length; i++) {
    const c = line[i];
    if (inQ) {
      if (c === '"' && line[i+1] === '"') { cur += '"'; i++; }
      else if (c === '"') inQ = false;
      else cur += c;
    } else {
      if (c === '"') inQ = true;
      else if (c === ',') { result.push(cur); cur = ''; }
      else cur += c;
    }
  }
  result.push(cur);
  return result;
}

